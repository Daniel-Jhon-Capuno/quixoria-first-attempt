# ─── Database (MySQL via XAMPP) ───────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Default XAMPP has no password for root, so:
DATABASE_URL=mysql://root:@localhost:3306/quixoria

# Individual DB fields (used by session store)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=quixoria

# ─── Session ──────────────────────────────────────────────────
# Change this to any long random string in production
SESSION_SECRET=my-super-secret-session-key-change-me

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
